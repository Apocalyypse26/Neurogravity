# Production Environment Variables for Vercel Frontend
# Add these in Vercel Dashboard → Settings → Environment Variables

# Supabase Configuration (get from your Supabase project settings)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API URL (update after Render deployment)
VITE_API_URL=https://neurox-api.onrender.com
